{
  "title": "Nginx — Load Balancer",
  "uid": "nginx-lb",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Up",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "nginx_up", "legendFormat": "up" }
      ]
    },
    {
      "id": 2,
      "title": "Requests per s",
      "type": "timeseries",
      "gridPos": { "x": 4, "y": 0, "w": 10, "h": 8 },
      "targets": [
        {
          "expr": "rate(nginx_http_requests_total[1m])",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 3,
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "x": 14, "y": 0, "w": 10, "h": 8 },
      "targets": [
        { "expr": "nginx_connections_active", "legendFormat": "active" }
      ]
    },
    {
      "id": 4,
      "title": "Connection States",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "nginx_connections_reading", "legendFormat": "reading" },
        { "expr": "nginx_connections_writing", "legendFormat": "writing" },
        { "expr": "nginx_connections_waiting", "legendFormat": "waiting" }
      ]
    },
    {
      "id": 5,
      "title": "Accepted vs Handled per s",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(nginx_connections_accepted[1m])", "legendFormat": "accepted" },
        { "expr": "rate(nginx_connections_handled[1m])", "legendFormat": "handled" }
      ]
    }
  ]
}
