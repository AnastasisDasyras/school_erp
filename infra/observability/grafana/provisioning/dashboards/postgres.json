{
  "title": "Postgres — Database",
  "uid": "postgres-db",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Up",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "pg_up", "legendFormat": "up" }
      ]
    },
    {
      "id": 2,
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "x": 4, "y": 0, "w": 10, "h": 8 },
      "targets": [
        {
          "expr": "sum(pg_stat_database_numbackends{datname=\"erp\"})",
          "legendFormat": "connections"
        }
      ]
    },
    {
      "id": 3,
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": { "x": 14, "y": 0, "w": 10, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_blks_hit{datname=\"erp\"}[5m])) / (sum(rate(pg_stat_database_blks_hit{datname=\"erp\"}[5m])) + sum(rate(pg_stat_database_blks_read{datname=\"erp\"}[5m])))",
          "legendFormat": "hit ratio"
        }
      ]
    },
    {
      "id": 4,
      "title": "Transactions (commit / rollback per s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"erp\"}[1m])",
          "legendFormat": "commit"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"erp\"}[1m])",
          "legendFormat": "rollback"
        }
      ]
    },
    {
      "id": 5,
      "title": "Rows Fetched / Returned per s",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_fetched{datname=\"erp\"}[1m])",
          "legendFormat": "fetched"
        },
        {
          "expr": "rate(pg_stat_database_tup_returned{datname=\"erp\"}[1m])",
          "legendFormat": "returned"
        }
      ]
    },
    {
      "id": 6,
      "title": "Deadlocks per s",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_deadlocks{datname=\"erp\"}[5m])",
          "legendFormat": "deadlocks"
        }
      ]
    }
  ]
}
