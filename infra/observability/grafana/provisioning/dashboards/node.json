{
  "title": "Node — Host",
  "uid": "node-host",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])))",
          "legendFormat": "cpu %"
        }
      ]
    },
    {
      "id": 2,
      "title": "Load Average (1m)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "node_load1", "legendFormat": "load1" }
      ]
    },
    {
      "id": 3,
      "title": "Memory Used (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
          "legendFormat": "mem %"
        }
      ]
    },
    {
      "id": 4,
      "title": "Filesystem Used (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 * (1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}))",
          "legendFormat": "root"
        }
      ]
    },
    {
      "id": 5,
      "title": "Network Throughput (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_bytes_total[1m]))",
          "legendFormat": "receive"
        },
        {
          "expr": "sum(rate(node_network_transmit_bytes_total[1m]))",
          "legendFormat": "transmit"
        }
      ]
    }
  ]
}
